{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "a1c7e5f2-8b3d-4e6a-9c1f-2d4b6e8a0c3f",
        "SanitizeTinyMce": true
      },
      "Content": {
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Hosting": {
        "Debug": true
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true,
        "CacheBuster": "Timestamp"
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "Admin1234!"
      },
      "Imaging": {
        "HMACSecretKey": "xDHxa4Z6dFwmdBkleKntrvSiQrnqCkEOcxRaRgLqa19nyyZNNxkkr1dgu2FYR1fmoZ4huqFUNr5SrTbAdZ0kMg=="
      }
    }
  },
  "uTPro": {
    "Feature": {
      "UrlViewer": {
        "SiteScan": {
          "//": "Recurring Site URL Scan config. All keys optional; values below are the defaults.",
          "Enabled": true,
          "//Period": "How often the scan runs (TimeSpan d.hh:mm:ss). Default 24 hours.",
          "Period": "24:00:00",
          "//Delay": "Delay before the first run after startup (TimeSpan). Default 5 minutes.",
          "Delay": "00:05:00",
          "//MaxConcurrency": "Max concurrent HTTP fetches, clamped 1..20. Default 4.",
          "MaxConcurrency": 4,
          "//ThrottleDelayMs": "Delay after each fetch (ms) to throttle load. Default 150.",
          "ThrottleDelayMs": 150,
          "SkipCloakingCheck": true,
          "//AllowInternalHosts": "SECURITY: relaxes the SSRF guard so private/local addresses can be scanned. Default false in production; true here so the local test site can scan itself.",
          "AllowInternalHosts": true,
          "RedirectWarningThreshold": 3,
          "MaxRunHistory": 20
        }
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
